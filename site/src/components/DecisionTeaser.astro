---
import Eyebrow from './Eyebrow.astro';
import Icon from './Icon.astro';
import { withBase } from '../lib/url';

const rows = [
  { want: 'Add reusable knowledge or a workflow Claude should auto-pick', use: 'Skill' },
  { want: 'Run a verbose investigation without polluting main context',  use: 'Subagent' },
  { want: 'Trigger something every time a tool runs or session starts',  use: 'Hook' },
  { want: 'Expose external services as callable tools',                  use: 'MCP server' },
  { want: 'Persistent project conventions for every session',            use: 'CLAUDE.md' },
  { want: 'A one-off command the user fires by name',                    use: 'Skill (manual)' },
];
---

<section class="teaser-section">
  <div class="teaser-inner">
    <div class="teaser-header">
      <Eyebrow>When to reach for what</Eyebrow>
      <h2 class="teaser-title serif">A five-minute decision guide.</h2>
      <p class="teaser-lead">
        Six primitives. One table. The rest of the chapter explains the trade-offs.
      </p>
    </div>

    <div class="teaser-card">
      <table class="teaser-table">
        <thead>
          <tr>
            <th>You want to&hellip;</th>
            <th>Use this primitive</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((r) => (
            <tr>
              <td>{r.want}</td>
              <td><span class="primitive">{r.use}</span></td>
            </tr>
          ))}
        </tbody>
      </table>

      <a href={withBase('/decide')} class="teaser-cta">
        Try the interactive decision flow
        <Icon name="arrow-right" size={14} />
      </a>
    </div>
  </div>
</section>

<style>
  .teaser-section {
    padding: 4rem 1.5rem;
    border-top: 1px solid var(--color-border);
  }
  @media (min-width: 1024px) {
    .teaser-section { padding: 6rem 1.75rem; }
  }
  .teaser-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  @media (min-width: 1024px) {
    .teaser-inner { grid-template-columns: 1fr 1.4fr; gap: 4rem; align-items: start; }
  }
  .teaser-header { max-width: 36ch; }
  .teaser-title {
    font-size: var(--text-display-md);
    font-weight: 500;
    color: var(--color-text-strong);
    margin: 0.85rem 0 1rem;
    letter-spacing: -0.014em;
    line-height: 1.15;
  }
  .teaser-lead {
    color: var(--color-text-muted);
    font-size: var(--text-ui);
    line-height: 1.6;
    margin: 0;
  }

  .teaser-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: 1.25rem;
    box-shadow: var(--shadow-sm);
  }
  @media (min-width: 768px) {
    .teaser-card { padding: 1.75rem 2rem 1.5rem; }
  }

  .teaser-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-ui);
  }
  .teaser-table th {
    text-align: left;
    font-size: var(--text-eyebrow);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-subtle);
    font-weight: 600;
    padding: 0 0.5rem 0.6rem;
    border-bottom: 1px solid var(--color-border);
  }
  .teaser-table th:last-child { text-align: right; }
  .teaser-table td {
    padding: 0.85rem 0.5rem;
    color: var(--color-text);
    border-bottom: 1px solid rgba(36, 48, 86, 0.5);
    line-height: 1.5;
    vertical-align: top;
  }
  .teaser-table td:last-child { text-align: right; }
  .teaser-table tbody tr:last-child td { border-bottom: 0; }

  .primitive {
    font-family: var(--font-mono);
    font-size: 0.92em;
    color: var(--color-amber);
    background: var(--color-amber-soft);
    padding: 0.18em 0.55em;
    border-radius: var(--radius-xs);
    border: 1px solid rgba(246,193,119,0.2);
    white-space: nowrap;
  }

  .teaser-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.4rem;
    padding: 0.55rem 0.85rem;
    color: var(--color-accent);
    font-size: var(--text-ui);
    font-weight: 500;
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: color var(--duration-fast) var(--ease-out),
                gap var(--duration-fast) var(--ease-out);
  }
  .teaser-cta:hover {
    color: var(--color-accent-hover);
    text-decoration: none;
    gap: 0.7rem;
  }
</style>
