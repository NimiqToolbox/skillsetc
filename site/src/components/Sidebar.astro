---
import { nav } from '../data/nav';
import SidebarGroup from './SidebarGroup.astro';
import SidebarLink from './SidebarLink.astro';

interface Props {
  currentSlug?: string;
}

const { currentSlug } = Astro.props;
---

<aside class="sidebar" data-pagefind-ignore aria-label="Documentation navigation">
  <nav class="sidebar-nav">
    {nav.map((group) => (
      <SidebarGroup label={group.label}>
        {group.items.map((item) => (
          <SidebarLink
            href={`/docs/${item.slug}`}
            label={item.label}
            description={item.description}
            active={currentSlug === item.slug}
          />
        ))}
      </SidebarGroup>
    ))}
  </nav>
</aside>

<style>
  .sidebar {
    position: sticky;
    top: var(--header-h);
    align-self: start;
    height: calc(100vh - var(--header-h));
    overflow-y: auto;
    padding: 2rem 1rem 2rem 0;
    width: var(--sidebar-w);
    flex-shrink: 0;
  }
  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  /* Hide on mobile by default — drawer behaviour handled by parent layout */
  @media (max-width: 1023px) {
    .sidebar { display: none; }
  }
</style>
