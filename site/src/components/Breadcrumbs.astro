---
import Icon from './Icon.astro';
import { withBase } from '../lib/url';

interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  crumbs: Crumb[];
}

const { crumbs } = Astro.props;
---

<nav class="breadcrumbs" aria-label="Breadcrumb">
  <ol>
    {crumbs.map((c, i) => (
      <li>
        {c.href && i < crumbs.length - 1 ? (
          <a href={withBase(c.href)}>{c.label}</a>
        ) : (
          <span aria-current="page">{c.label}</span>
        )}
        {i < crumbs.length - 1 && (
          <Icon name="chevron-right" size={12} class="bc-sep" />
        )}
      </li>
    ))}
  </ol>
</nav>

<style>
  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
    margin: 0 0 1rem;
    padding: 0;
    list-style: none;
    font-size: var(--text-caption);
    color: var(--color-text-subtle);
  }
  .breadcrumbs li {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .breadcrumbs a {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }
  .breadcrumbs a:hover { color: var(--color-text); text-decoration: none; }
  .breadcrumbs span[aria-current] { color: var(--color-text-strong); font-weight: 500; }
  .bc-sep { color: var(--color-border-strong); flex-shrink: 0; }
</style>
