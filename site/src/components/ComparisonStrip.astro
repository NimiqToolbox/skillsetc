---
import Eyebrow from './Eyebrow.astro';
import Icon from './Icon.astro';
import { withBase } from '../lib/url';

const claudeFeatures = [
  { k: 'CLI',           v: 'claude' },
  { k: 'Memory',        v: 'CLAUDE.md' },
  { k: 'Context',       v: 'up to 1M (Opus 4.7)' },
  { k: 'Subagents',     v: 'auto-delegated by description' },
  { k: 'Cloud agent',   v: 'limited (Managed Agents)' },
];

const codexFeatures = [
  { k: 'CLI',           v: 'codex' },
  { k: 'Memory',        v: 'AGENTS.md (open standard)' },
  { k: 'Models',        v: 'gpt-5.5 · gpt-5.4 · gpt-5.4-mini' },
  { k: 'Subagents',     v: 'explicit user request only' },
  { k: 'Cloud agent',   v: 'first-class — chatgpt.com/codex' },
];
---

<section class="strip-section">
  <div class="strip-inner">
    <div class="strip-header">
      <Eyebrow>Two coding agents, side-by-side</Eyebrow>
      <h2 class="strip-title serif">Claude Code <em>vs</em> OpenAI Codex.</h2>
      <p class="strip-lead">
        They share the open SKILL.md and AGENTS.md standards, ship comparable CLIs, and target
        the same workflows — but they diverge sharply on cloud strategy, sandbox model, and how
        subagents get spawned.
      </p>
    </div>

    <div class="strip-cards">
      <article class="vs-card vs-claude">
        <header class="vs-card-head">
          <span class="vs-mark vs-mark-claude" aria-hidden="true">▲</span>
          <h3 class="vs-name serif">Claude Code</h3>
        </header>
        <ul class="vs-list">
          {claudeFeatures.map((f) => (
            <li><span class="vs-key">{f.k}</span><span class="vs-val">{f.v}</span></li>
          ))}
        </ul>
      </article>

      <div class="vs-divider" aria-hidden="true">
        <span class="vs-divider-text">vs</span>
      </div>

      <article class="vs-card vs-codex">
        <header class="vs-card-head">
          <span class="vs-mark vs-mark-codex" aria-hidden="true">◆</span>
          <h3 class="vs-name serif">OpenAI Codex</h3>
        </header>
        <ul class="vs-list">
          {codexFeatures.map((f) => (
            <li><span class="vs-key">{f.k}</span><span class="vs-val">{f.v}</span></li>
          ))}
        </ul>
      </article>
    </div>

    <a href={withBase('/docs/comparison-and-decision-guide')} class="strip-cta">
      Open the comparison
      <Icon name="arrow-right" size={14} />
    </a>
  </div>
</section>

<style>
  .strip-section {
    position: relative;
    padding: 5rem 1.5rem 6rem;
    border-top: 1px solid var(--color-border);
    overflow: hidden;
  }
  @media (min-width: 1024px) {
    .strip-section { padding: 7rem 1.75rem 8rem; }
  }
  .strip-section::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 20% 30%, rgba(124,140,255,0.08), transparent 60%),
      radial-gradient(ellipse 60% 50% at 80% 70%, rgba(246,193,119,0.06), transparent 60%);
    pointer-events: none;
  }
  .strip-inner {
    position: relative;
    max-width: var(--container-max);
    margin: 0 auto;
  }

  .strip-header {
    text-align: center;
    max-width: 50ch;
    margin: 0 auto 3rem;
  }
  .strip-title {
    font-size: var(--text-display-md);
    font-weight: 500;
    color: var(--color-text-strong);
    margin: 0.85rem 0 1rem;
    letter-spacing: -0.014em;
    line-height: 1.15;
  }
  .strip-title em {
    font-style: italic;
    color: var(--color-text-subtle);
    font-weight: 400;
    margin: 0 0.15em;
  }
  .strip-lead {
    color: var(--color-text-muted);
    font-size: var(--text-ui);
    line-height: 1.65;
    margin: 0;
  }

  .strip-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    align-items: stretch;
  }
  @media (min-width: 768px) {
    .strip-cards { grid-template-columns: 1fr auto 1fr; gap: 1rem; }
  }

  .vs-card {
    padding: 1.75rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .vs-claude { border-color: rgba(124,140,255,0.20); }
  .vs-codex  { border-color: rgba(246,193,119,0.20); }

  .vs-card-head {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .vs-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.85rem;
    height: 1.85rem;
    border-radius: var(--radius-sm);
    font-size: 0.85rem;
  }
  .vs-mark-claude { background: var(--color-accent-soft); color: var(--color-accent); }
  .vs-mark-codex  { background: var(--color-amber-soft);  color: var(--color-amber); }
  .vs-name { font-size: 1.25rem; font-weight: 500; color: var(--color-text-strong); margin: 0; letter-spacing: -0.01em; }

  .vs-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .vs-list li {
    display: grid;
    grid-template-columns: 6.5rem 1fr;
    gap: 0.75rem;
    font-size: var(--text-ui);
    line-height: 1.45;
  }
  .vs-key {
    color: var(--color-text-subtle);
    font-size: var(--text-caption);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding-top: 0.15em;
  }
  .vs-val {
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 0.92em;
  }

  .vs-divider {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .vs-divider-text {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.4rem;
    color: var(--color-text-subtle);
    padding: 0.5rem 0.9rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
  }

  .strip-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin: 2.5rem auto 0;
    padding: 0.7rem 1.1rem;
    background: var(--color-accent);
    color: #0B1020;
    font-size: var(--text-ui);
    font-weight: 500;
    border-radius: var(--radius-sm);
    text-decoration: none;
    box-shadow: var(--shadow-sm);
    transition: transform var(--duration-fast) var(--ease-out),
                box-shadow var(--duration-fast) var(--ease-out),
                background var(--duration-fast) var(--ease-out);
  }
  .strip-cta:hover {
    background: var(--color-accent-hover);
    color: #0B1020;
    transform: translateY(-1px);
    box-shadow: var(--shadow-md), var(--shadow-glow);
    text-decoration: none;
  }
  .strip-section { display: flex; flex-direction: column; }
  .strip-inner { display: flex; flex-direction: column; align-items: center; }
  .strip-header { width: 100%; }
  .strip-cards { width: 100%; }
</style>
