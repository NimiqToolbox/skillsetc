---
import Eyebrow from './Eyebrow.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;

// Only show H2 + H3
const filtered = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filtered.length > 0 && (
  <aside class="toc" data-pagefind-ignore aria-label="Table of contents">
    <Eyebrow class="toc-eyebrow">On this page</Eyebrow>
    <ul class="toc-list">
      {filtered.map((h) => (
        <li class:list={['toc-item', `toc-d${h.depth}`]}>
          <a href={`#${h.slug}`} data-toc-link={h.slug}>{h.text}</a>
        </li>
      ))}
    </ul>
  </aside>
)}

<style>
  .toc {
    position: sticky;
    top: calc(var(--header-h) + 1rem);
    align-self: start;
    width: var(--toc-w);
    flex-shrink: 0;
    padding: 1rem 0;
    max-height: calc(100vh - var(--header-h) - 2rem);
    overflow-y: auto;
  }
  .toc-eyebrow { display: inline-block; margin-bottom: 0.85rem; padding-left: 0.85rem; }
  .toc-list { list-style: none; margin: 0; padding: 0; }
  .toc-item a {
    display: block;
    padding: 0.4rem 0.85rem;
    font-size: var(--text-caption);
    line-height: 1.45;
    color: var(--color-text-subtle);
    border-left: 2px solid transparent;
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out),
                border-color var(--duration-fast) var(--ease-out),
                background var(--duration-fast) var(--ease-out);
  }
  .toc-item.toc-d3 a { padding-left: 1.65rem; font-size: 0.78rem; }
  .toc-item a:hover {
    color: var(--color-text);
    text-decoration: none;
  }
  .toc-item a[aria-current="true"] {
    color: var(--color-text-strong);
    border-left-color: var(--color-amber);
    background: var(--color-amber-soft);
  }

  @media (max-width: 1279px) {
    .toc { display: none; }
  }
</style>

<script>
  // Scroll-spy: highlight current heading in the TOC
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]');
  if (tocLinks.length > 0) {
    const linkBySlug = new Map<string, HTMLAnchorElement>();
    tocLinks.forEach((a) => linkBySlug.set(a.dataset.tocLink!, a));

    const headings: Element[] = [];
    linkBySlug.forEach((_, slug) => {
      const el = document.getElementById(slug);
      if (el) headings.push(el);
    });

    let current: string | null = null;

    const setCurrent = (slug: string | null) => {
      if (slug === current) return;
      current = slug;
      tocLinks.forEach((a) => a.setAttribute('aria-current', a.dataset.tocLink === slug ? 'true' : 'false'));
    };

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
        if (visible.length > 0) {
          setCurrent(visible[0].target.id);
        } else {
          // No headings intersecting — pick the last passed heading
          const passed = headings
            .map((h) => ({ id: h.id, top: h.getBoundingClientRect().top }))
            .filter((h) => h.top < 80)
            .sort((a, b) => b.top - a.top);
          if (passed[0]) setCurrent(passed[0].id);
        }
      },
      { rootMargin: '-72px 0px -65% 0px', threshold: 0 },
    );

    headings.forEach((h) => observer.observe(h));
  }
</script>
