---
import Icon from './Icon.astro';
import { hostnameOf } from '../lib/format';

interface Props {
  sources: string[];
}

const { sources } = Astro.props;
---

{sources.length > 0 && (
  <section class="sources-panel" aria-label="Sources">
    <header class="sources-header">
      <span class="sources-eyebrow">Sourced from</span>
    </header>
    <ul class="sources-list">
      {sources.map((url) => (
        <li>
          <a href={url} target="_blank" rel="noopener noreferrer">
            <span class="sources-host">{hostnameOf(url)}</span>
            <span class="sources-path">{new URL(url).pathname.replace(/\/$/, '')}</span>
            <Icon name="external" size={12} class="sources-icon" />
          </a>
        </li>
      ))}
    </ul>
  </section>
)}

<style>
  .sources-panel {
    margin: 2rem 0 2.5rem;
    padding: 1rem 1.1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }
  .sources-eyebrow {
    font-size: var(--text-eyebrow);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-subtle);
    font-weight: 600;
  }
  .sources-list {
    list-style: none;
    margin: 0.6rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .sources-list a {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
    font-size: var(--text-caption);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }
  .sources-list a:hover { color: var(--color-accent); text-decoration: none; }
  .sources-host {
    font-family: var(--font-mono);
    color: var(--color-text);
    font-weight: 500;
  }
  .sources-path {
    font-family: var(--font-mono);
    color: var(--color-text-subtle);
    word-break: break-all;
  }
  .sources-icon {
    color: var(--color-text-subtle);
    flex-shrink: 0;
    margin-left: 0.2rem;
    align-self: center;
  }
</style>
